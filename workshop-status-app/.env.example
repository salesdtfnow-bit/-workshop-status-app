# Your Shopify store's .myshopify.com domain.
# Find this in Shopify admin under Settings → Domains → "myshopify.com domain"
# For DTF Now this is d0dc54-ad.myshopify.com (NOT dtfnow.myshopify.com — that's the public domain)
SHOPIFY_SHOP_DOMAIN=d0dc54-ad.myshopify.com

# Admin API access token from your Shopify Custom App.
# Get this by going to: Settings → Apps and sales channels → Develop apps → [Your app] → API credentials
# IMPORTANT: this token starts with "shpat_" — keep it secret, never commit it to git.
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A long random secret string that protects the app's API.
# Generate one with this command in a terminal:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASS=replace-with-a-long-random-secret-string
