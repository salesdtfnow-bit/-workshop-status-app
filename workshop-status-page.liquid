<section id="WS3-{{ section.id }}" aria-labelledby="WS3H-{{ section.id }}">
  <div class="ws-wrap">

    <header class="ws-head">
      {% if section.settings.eyebrow != blank %}
        <div class="ws-eyebrow">
          <span class="ws-eyebrow-dot"></span>
          {{ section.settings.eyebrow | escape }}
        </div>
      {% endif %}
      <h1 id="WS3H-{{ section.id }}" class="ws-h1">{{ section.settings.heading | escape }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="ws-sub">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </header>

    {% liquid
      assign oc = overall_status | downcase | replace: ' ', '_' | replace: '-', '_'
      assign ocl = 'green'
      assign overall_label = 'Not Busy'
      if oc == 'moderate'
        assign ocl = 'amber'
        assign overall_label = 'Moderate'
      elsif oc == 'busy'
        assign ocl = 'orange'
        assign overall_label = 'Busy'
      elsif oc == 'full_capacity'
        assign ocl = 'red'
        assign overall_label = 'Full Capacity'
      endif
    %}

    <div class="ws-hero">
      <div class="ws-hero-info">
        <p class="ws-label">Overall status</p>
        <h2 class="ws-hero-title">Workshop capacity</h2>
        <p class="ws-hero-desc">{{ section.settings.overall_description | escape }}</p>
        <div class="ws-time">
          {{ icon_clock }}
          {% if overall_updated != blank %}
            <span>Updated {{ overall_updated | date: section.settings.date_format }}</span>
          {% else %}
            <span>Status is live</span>
          {% endif %}
        </div>
      </div>
      <span class="ws-pill ws-pill-lg ws-s-{{ ocl }}">
        <span class="ws-pill-dot"></span>
        {{ overall_label }}
      </span>
    </div>

    <div class="ws-grid">

      {% liquid
        assign dc = dtf_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign dcl = 'green'
        assign dtf_label = 'Not Busy'
        if dc == 'moderate'
          assign dcl = 'amber'
          assign dtf_label = 'Moderate'
        elsif dc == 'busy'
          assign dcl = 'orange'
          assign dtf_label = 'Busy'
        elsif dc == 'full_capacity'
          assign dcl = 'red'
          assign dtf_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">DTF production</h3>
          <div class="ws-card-icon ws-icon-{{ dcl }}">{{ icon_printer }}</div>
        </div>
        <p class="ws-card-desc">Direct-to-film transfer production queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-s-{{ dcl }}">
            <span class="ws-pill-dot"></span>
            {{ dtf_label }}
          </span>
          <span class="ws-foot-time">{% if dtf_updated != blank %}{{ dtf_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
      </div>

      {% liquid
        assign uc = uv_dtf_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign ucl = 'green'
        assign uv_dtf_label = 'Not Busy'
        if uc == 'moderate'
          assign ucl = 'amber'
          assign uv_dtf_label = 'Moderate'
        elsif uc == 'busy'
          assign ucl = 'orange'
          assign uv_dtf_label = 'Busy'
        elsif uc == 'full_capacity'
          assign ucl = 'red'
          assign uv_dtf_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">UV-DTF production</h3>
          <div class="ws-card-icon ws-icon-{{ ucl }}">{{ icon_diamond }}</div>
        </div>
        <p class="ws-card-desc">UV-DTF transfer print production queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-s-{{ ucl }}">
            <span class="ws-pill-dot"></span>
            {{ uv_dtf_label }}
          </span>
          <span class="ws-foot-time">{% if uv_dtf_updated != blank %}{{ uv_dtf_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
      </div>

      {% liquid
        assign vc = vinyl_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign vcl = 'green'
        assign vinyl_label = 'Not Busy'
        if vc == 'moderate'
          assign vcl = 'amber'
          assign vinyl_label = 'Moderate'
        elsif vc == 'busy'
          assign vcl = 'orange'
          assign vinyl_label = 'Busy'
        elsif vc == 'full_capacity'
          assign vcl = 'red'
          assign vinyl_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">Vinyl stickers</h3>
          <div class="ws-card-icon ws-icon-{{ vcl }}">{{ icon_tag }}</div>
        </div>
        <p class="ws-card-desc">Vinyl sticker printing and finishing queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-s-{{ vcl }}">
            <span class="ws-pill-dot"></span>
            {{ vinyl_label }}
          </span>
          <span class="ws-foot-time">{% if vinyl_updated != blank %}{{ vinyl_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
      </div>

      {% liquid
        assign sc = sublimation_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign scl = 'green'
        assign sublimation_label = 'Not Busy'
        if sc == 'moderate'
          assign scl = 'amber'
          assign sublimation_label = 'Moderate'
        elsif sc == 'busy'
          assign scl = 'orange'
          assign sublimation_label = 'Busy'
        elsif sc == 'full_capacity'
          assign scl = 'red'
          assign sublimation_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">Sublimation</h3>
          <div class="ws-card-icon ws-icon-{{ scl }}">{{ icon_palette }}</div>
        </div>
        <p class="ws-card-desc">Sublimation production work queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-s-{{ scl }}">
            <span class="ws-pill-dot"></span>
            {{ sublimation_label }}
          </span>
          <span class="ws-foot-time">{% if sublimation_updated != blank %}{{ sublimation_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
      </div>

      {% liquid
        assign ac = artwork_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign acl = 'green'
        assign artwork_label = 'Not Busy'
        if ac == 'moderate'
          assign acl = 'amber'
          assign artwork_label = 'Moderate'
        elsif ac == 'busy'
          assign acl = 'orange'
          assign artwork_label = 'Busy'
        elsif ac == 'full_capacity'
          assign acl = 'red'
          assign artwork_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">Artwork setup</h3>
          <div class="ws-card-icon ws-icon-{{ acl }}">{{ icon_pencil }}</div>
        </div>
        <p class="ws-card-desc">Artwork checks, file prep and setup queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-s-{{ acl }}">
            <span class="ws-pill-dot"></span>
            {{ artwork_label }}
          </span>
          <span class="ws-foot-time">{% if artwork_updated != blank %}{{ artwork_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
      </div>

    </div>

    {% if section.settings.footer_note != blank %}
      <div class="ws-footer">
        <p>{{ section.settings.footer_note | escape }}</p>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Workshop status page",
  "class": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",             "label": "Badge text",        "default": "Live Status" },
    { "type": "text",     "id": "heading",             "label": "Heading",           "default": "Workshop Status" },
    { "type": "textarea","id": "subheading",           "label": "Intro text",        "default": "Check our current workshop capacity before placing an order. Statuses update in real time as production queues change." },
    { "type": "textarea","id": "overall_description",  "label": "Overall description","default": "A live summary of our current production workload across all departments." },
    { "type": "textarea","id": "footer_note",          "label": "Footer note",       "default": "Status is a guide only. For urgent orders, please contact us to confirm current lead times." },
    { "type": "text",     "id": "date_format",         "label": "Date format",       "default": "%d %b %Y, %H:%M" },
    { "type": "color",   "id": "background_color",     "label": "Background colour", "default": "#f8f9fa" },
    { "type": "color",   "id": "card_background_color","label": "Card background",   "default": "#ffffff" },
    { "type": "color",   "id": "text_color",           "label": "Text colour",       "default": "#111827" },
    { "type": "color",   "id": "muted_text_color",     "label": "Secondary text",    "default": "#6b7280" },
    { "type": "range",   "id": "padding_top",    "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Top padding",    "default": 56 },
    { "type": "range",   "id": "padding_bottom", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 56 }
  ],
  "presets": [
    { "name": "Workshop status page" }
  ]
}
{% endschema %}
