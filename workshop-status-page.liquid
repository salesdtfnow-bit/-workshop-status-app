<section id="WS3-{{ section.id }}" aria-labelledby="WS3H-{{ section.id }}">
  <div class="ws-wrap">

    <header class="ws-head">
      {% if section.settings.eyebrow != blank %}
        <div class="ws-eyebrow">
          <span class="ws-eyebrow-dot"></span>
          {{ section.settings.eyebrow | escape }}
        </div>
      {% endif %}
      <h1 id="WS3H-{{ section.id }}" class="ws-h1">{{ section.settings.heading | escape }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="ws-sub">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </header>

    {% liquid
      assign oc = overall_status | downcase | replace: ' ', '_' | replace: '-', '_'
      assign ocl = 'green'
      assign overall_label = 'Not Busy'
      if oc == 'moderate'
        assign ocl = 'amber'
        assign overall_label = 'Moderate'
      elsif oc == 'busy'
        assign ocl = 'orange'
        assign overall_label = 'Busy'
      elsif oc == 'full_capacity'
        assign ocl = 'red'
        assign overall_label = 'Full Capacity'
      endif
    %}

    <div class="ws-hero">
      <div class="ws-hero-info">
        <p class="ws-label">Overall status</p>
        <h2 class="ws-hero-title">Workshop capacity</h2>
        <p class="ws-hero-desc">{{ section.settings.overall_description | escape }}</p>
        <div class="ws-time">
          {{ icon_clock }}
          {% if overall_updated != blank %}
            <span>Updated <span class="ws-rel" data-iso="{{ overall_updated }}">{{ overall_updated | date: section.settings.date_format }}</span></span>
          {% else %}
            <span>Status is live</span>
          {% endif %}
        </div>
      </div>
      <span class="ws-pill ws-pill-lg ws-pill-hero ws-s-{{ ocl }}">
        <span class="ws-pill-dot"></span>
        {{ overall_label }}
      </span>
    </div>

    <div class="ws-grid">

      {% liquid
        assign dc = dtf_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign dcl = 'green'
        assign dtf_label = 'Not Busy'
        if dc == 'moderate'
          assign dcl = 'amber'
          assign dtf_label = 'Moderate'
        elsif dc == 'busy'
          assign dcl = 'orange'
          assign dtf_label = 'Busy'
        elsif dc == 'full_capacity'
          assign dcl = 'red'
          assign dtf_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card ws-card-dtf">
        <div class="ws-card-head">
          <h3 class="ws-card-title">DTF production</h3>
          <div class="ws-card-icon ws-icon-{{ dcl }}">{{ icon_printer }}</div>
        </div>
        <p class="ws-card-desc">Direct-to-film transfer production queue.</p>

        {% if dtf_cap_total > 0 %}
          <div class="ws-cap">
            <div class="ws-cap-head">
              <span class="ws-cap-label">Daily capacity</span>
              <span class="ws-cap-figs">{{ dtf_cap_used }}m / {{ dtf_cap_total }}m · {{ dtf_cap_pct | floor }}% full</span>
            </div>
            <div class="ws-cap-bar"><div class="ws-cap-fill ws-cap-{{ dtf_cap_color }}" style="width:{{ dtf_cap_pct_clamped }}%"></div></div>
            {% if dtf_dispatch_msg != blank %}
              <p class="ws-cap-eta">{{ dtf_dispatch_msg }}</p>
            {% endif %}
          </div>
        {% endif %}

        <div class="ws-machines">
          {% liquid
            assign ma_online_str = machine_a_online | downcase
            assign mb_online_str = machine_b_online | downcase
            assign ma_is_on = false
            assign mb_is_on = false
            if ma_online_str == 'true'
              assign ma_is_on = true
            endif
            if mb_online_str == 'true'
              assign mb_is_on = true
            endif
          %}
          <div class="ws-machine{% if ma_is_on %} on{% else %} off{% endif %}">
            <div class="ws-machine-head">
              <span class="ws-machine-name">Machine A</span>
              <span class="ws-machine-dot"></span>
              <span class="ws-machine-state">{% if ma_is_on %}Online{% else %}Offline{% endif %}</span>
            </div>
            <div class="ws-machine-q">{{ machine_a_queue }}m setup</div>
          </div>
          <div class="ws-machine{% if mb_is_on %} on{% else %} off{% endif %}">
            <div class="ws-machine-head">
              <span class="ws-machine-name">Machine B</span>
              <span class="ws-machine-dot"></span>
              <span class="ws-machine-state">{% if mb_is_on %}Online{% else %}Offline{% endif %}</span>
            </div>
            <div class="ws-machine-q">{{ machine_b_queue }}m setup</div>
          </div>
        </div>

        <div class="ws-card-foot">
          <span class="ws-pill ws-pill-hero ws-s-{{ dcl }}">
            <span class="ws-pill-dot"></span>
            {{ dtf_label }}
          </span>
          <span class="ws-foot-time ws-rel" data-iso="{{ dtf_updated }}">{% if dtf_updated != blank %}{{ dtf_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
        {% liquid
          assign cta_key_dept = dtf_status | downcase | replace: ' ', '_' | replace: '-', '_'
          assign show_dept_cta = false
          if section.settings.dtf_cta_label != blank and section.settings.dtf_cta_link != blank
            if cta_key_dept != 'full_capacity'
              assign show_dept_cta = true
            endif
          endif
        %}
        {% if show_dept_cta %}
          <div class="ws-card-cta">
            <a class="ws-card-cta-btn" href="{{ section.settings.dtf_cta_link }}">
              {{ section.settings.dtf_cta_label | escape }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        {% endif %}
      </div>

      {% liquid
        assign uc = uv_dtf_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign ucl = 'green'
        assign uv_dtf_label = 'Not Busy'
        if uc == 'moderate'
          assign ucl = 'amber'
          assign uv_dtf_label = 'Moderate'
        elsif uc == 'busy'
          assign ucl = 'orange'
          assign uv_dtf_label = 'Busy'
        elsif uc == 'full_capacity'
          assign ucl = 'red'
          assign uv_dtf_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">UV-DTF production</h3>
          <div class="ws-card-icon ws-icon-{{ ucl }}">{{ icon_diamond }}</div>
        </div>
        <p class="ws-card-desc">UV-DTF transfer print production queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-pill-hero ws-s-{{ ucl }}">
            <span class="ws-pill-dot"></span>
            {{ uv_dtf_label }}
          </span>
          <span class="ws-foot-time ws-rel" data-iso="{{ uv_dtf_updated }}">{% if uv_dtf_updated != blank %}{{ uv_dtf_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
        {% liquid
          assign cta_key_dept = uv_dtf_status | downcase | replace: ' ', '_' | replace: '-', '_'
          assign show_dept_cta = false
          if section.settings.uv_dtf_cta_label != blank and section.settings.uv_dtf_cta_link != blank
            if cta_key_dept != 'full_capacity'
              assign show_dept_cta = true
            endif
          endif
        %}
        {% if show_dept_cta %}
          <div class="ws-card-cta">
            <a class="ws-card-cta-btn" href="{{ section.settings.uv_dtf_cta_link }}">
              {{ section.settings.uv_dtf_cta_label | escape }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        {% endif %}
      </div>

      {% liquid
        assign ac = artwork_status | downcase | replace: ' ', '_' | replace: '-', '_'
        assign acl = 'green'
        assign artwork_label = 'Not Busy'
        if ac == 'moderate'
          assign acl = 'amber'
          assign artwork_label = 'Moderate'
        elsif ac == 'busy'
          assign acl = 'orange'
          assign artwork_label = 'Busy'
        elsif ac == 'full_capacity'
          assign acl = 'red'
          assign artwork_label = 'Full Capacity'
        endif
      %}
      <div class="ws-card">
        <div class="ws-card-head">
          <h3 class="ws-card-title">Artwork setup</h3>
          <div class="ws-card-icon ws-icon-{{ acl }}">{{ icon_pencil }}</div>
        </div>
        <p class="ws-card-desc">Artwork checks, file prep and setup queue.</p>
        <div class="ws-card-foot">
          <span class="ws-pill ws-pill-hero ws-s-{{ acl }}">
            <span class="ws-pill-dot"></span>
            {{ artwork_label }}
          </span>
          <span class="ws-foot-time ws-rel" data-iso="{{ artwork_updated }}">{% if artwork_updated != blank %}{{ artwork_updated | date: section.settings.date_format }}{% else %}—{% endif %}</span>
        </div>
        {% liquid
          assign cta_key_dept = artwork_status | downcase | replace: ' ', '_' | replace: '-', '_'
          assign show_dept_cta = false
          if section.settings.artwork_cta_label != blank and section.settings.artwork_cta_link != blank
            if cta_key_dept != 'full_capacity'
              assign show_dept_cta = true
            endif
          endif
        %}
        {% if show_dept_cta %}
          <div class="ws-card-cta">
            <a class="ws-card-cta-btn" href="{{ section.settings.artwork_cta_link }}">
              {{ section.settings.artwork_cta_label | escape }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        {% endif %}
      </div>

    </div>

    {% liquid
      assign overall_key = overall_status | downcase | replace: ' ', '_' | replace: '-', '_'
      assign show_cta = false
      if section.settings.cta_label != blank and section.settings.cta_link != blank
        if overall_key != 'full_capacity'
          assign show_cta = true
        endif
      endif
    %}
    {% if show_cta %}
      <div class="ws-cta-wrap">
        <a class="ws-cta-btn" href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label | escape }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
        {% if section.settings.cta_note != blank %}
          <p class="ws-cta-note">{{ section.settings.cta_note | escape }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.tracker_show %}
      <div class="ws-tracker" id="WS3-tracker-{{ section.id }}">
        <h3>{{ section.settings.tracker_heading | default: 'Track your order' | escape }}</h3>
        <p>{{ section.settings.tracker_subtext | default: 'Enter your order number to see if it has been set up and on which machine.' | escape }}</p>
        <form data-tracker-form>
          <input type="text" name="order" placeholder="Order number (e.g. 1234)" autocomplete="off" required />
          <button type="submit">Track</button>
        </form>
        <div class="result" data-tracker-result style="display:none"></div>
      </div>
    {% endif %}

    {% if section.settings.footer_note != blank %}
      <div class="ws-footer">
        <p>{{ section.settings.footer_note | escape }}</p>
      </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  var section = document.getElementById('WS3-{{ section.id }}');
  if (!section) return;

  function rel(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    if (isNaN(d)) return '';
    var diff = Math.floor((Date.now() - d.getTime()) / 1000);
    if (diff < 5) return 'just now';
    if (diff < 60) return diff + 's ago';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
    return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
  }
  function refreshRel() {
    section.querySelectorAll('.ws-rel[data-iso]').forEach(function(el) {
      var iso = el.getAttribute('data-iso');
      if (!iso) return;
      var t = rel(iso);
      if (t) el.textContent = t;
    });
  }

  refreshRel();
  setInterval(refreshRel, 60 * 1000);

  // ─── Order tracker form ─────────────────────────────────────────────
  var trackerWrap = document.getElementById('WS3-tracker-{{ section.id }}');
  if (trackerWrap) {
    var trackerForm = trackerWrap.querySelector('[data-tracker-form]');
    var trackerResult = trackerWrap.querySelector('[data-tracker-result]');
    var trackerEndpoint = {{ section.settings.tracker_api | json }};
    trackerForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var raw = trackerForm.elements.order.value.trim();
      if (!raw) return;
      var num = raw.replace(/^#/, '');
      trackerResult.style.display = 'block';
      trackerResult.className = 'result';
      trackerResult.textContent = 'Looking up #' + num + '…';
      var endpoint = trackerEndpoint || 'https://workshop-status-app.vercel.app/api/track';
      fetch(endpoint + '?order=' + encodeURIComponent(num))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.found) {
            trackerResult.className = 'result error';
            trackerResult.innerHTML = '<strong>Not found.</strong> Double-check the order number.';
            return;
          }
          var setupLine = data.setupAt
            ? 'Set up on Machine ' + (data.machine || '?') + ' on ' + rel(data.setupAt) + ' (' + new Date(data.setupAt).toLocaleString('en-GB') + ')'
            : 'Not yet set up on a machine.';
          var statusLine = 'Status: ' + (data.fulfillmentStatus || '—');
          trackerResult.className = 'result ok';
          trackerResult.innerHTML =
            '<strong>Order ' + data.name + '</strong>' +
            setupLine + '<br>' +
            statusLine;
        })
        .catch(function() {
          trackerResult.className = 'result error';
          trackerResult.textContent = 'Lookup failed. Please try again.';
        });
    });
  }
})();
</script>


{% schema %}
{
  "name": "Workshop status page",
  "class": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",             "label": "Badge text",        "default": "Live Status" },
    { "type": "text",     "id": "heading",             "label": "Heading",           "default": "Workshop Status" },
    { "type": "textarea", "id": "subheading",          "label": "Intro text",        "default": "Check our current workshop capacity before placing an order. Statuses update in real time as production queues change." },
    { "type": "textarea", "id": "overall_description", "label": "Overall description","default": "A live summary of our current production workload across all departments." },
    { "type": "textarea", "id": "footer_note",         "label": "Footer note",       "default": "Status is a guide only. For urgent orders, please contact us to confirm current lead times." },
    { "type": "text",     "id": "date_format",         "label": "Date format",       "default": "%d %b %Y, %H:%M" },
    { "type": "header",   "content": "Per-department CTAs" },
    { "type": "paragraph","content": "Each card has its own CTA linking to the relevant product or collection. Hidden when that department is at Full Capacity, or when the link is blank." },
    { "type": "text",     "id": "dtf_cta_label",         "label": "DTF — Button label",            "default": "Shop DTF transfers" },
    { "type": "url",      "id": "dtf_cta_link",          "label": "DTF — Button link" },
    { "type": "text",     "id": "uv_dtf_cta_label",      "label": "UV-DTF — Button label",         "default": "Shop UV-DTF" },
    { "type": "url",      "id": "uv_dtf_cta_link",       "label": "UV-DTF — Button link" },
    { "type": "text",     "id": "artwork_cta_label",     "label": "Artwork setup — Button label",  "default": "Submit artwork" },
    { "type": "url",      "id": "artwork_cta_link",      "label": "Artwork setup — Button link" },
    { "type": "header",   "content": "Order tracker" },
    { "type": "checkbox", "id": "tracker_show",        "label": "Show order tracker form", "default": true },
    { "type": "text",     "id": "tracker_heading",     "label": "Tracker heading",   "default": "Track your order" },
    { "type": "textarea", "id": "tracker_subtext",     "label": "Tracker subtext",   "default": "Enter your order number to see if it has been set up and on which machine." },
