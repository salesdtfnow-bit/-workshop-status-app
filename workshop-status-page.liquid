{% comment %}
  Workshop Status Page Section — v3.1 (timestamp + label fixes)
  File: sections/workshop-status-page.liquid

  Reads shop metafields from namespace `workshop_status`:
    * Status fields (text)   : overall, dtf, uv_dtf, vinyl_stickers, sublimation, artwork_setup
    * Updated fields (date)  : overall_updated, dtf_updated, uv_dtf_updated,
                               vinyl_stickers_updated, sublimation_updated, artwork_setup_updated

  Status keys may be stored as snake_case (not_busy, full_capacity) OR as
  display labels (Not Busy, Full Capacity) — the template normalises both.
{% endcomment %}

{% liquid
  assign overall_mf  = shop.metafields.workshop_status.overall
  assign overall_status = overall_mf.value.status | default: ''
  if overall_status == blank
    assign overall_status = overall_mf.value | default: ''
  endif
  if overall_status == blank
    assign overall_status = overall_mf | default: ''
  endif

  assign dtf_mf = shop.metafields.workshop_status.dtf
  assign dtf_status = dtf_mf.value.status | default: ''
  if dtf_status == blank
    assign dtf_status = dtf_mf.value | default: ''
  endif
  if dtf_status == blank
    assign dtf_status = dtf_mf | default: ''
  endif

  assign uv_dtf_mf = shop.metafields.workshop_status.uv_dtf
  assign uv_dtf_status = uv_dtf_mf.value.status | default: ''
  if uv_dtf_status == blank
    assign uv_dtf_status = uv_dtf_mf.value | default: ''
  endif
  if uv_dtf_status == blank
    assign uv_dtf_status = uv_dtf_mf | default: ''
  endif

  assign vinyl_mf = shop.metafields.workshop_status.vinyl_stickers
  assign vinyl_status = vinyl_mf.value.status | default: ''
  if vinyl_status == blank
    assign vinyl_status = vinyl_mf.value | default: ''
  endif
  if vinyl_status == blank
    assign vinyl_status = vinyl_mf | default: ''
  endif

  assign sublimation_mf = shop.metafields.workshop_status.sublimation
  assign sublimation_status = sublimation_mf.value.status | default: ''
  if sublimation_status == blank
    assign sublimation_status = sublimation_mf.value | default: ''
  endif
  if sublimation_status == blank
    assign sublimation_status = sublimation_mf | default: ''
  endif

  assign artwork_mf = shop.metafields.workshop_status.artwork_setup
  assign artwork_status = artwork_mf.value.status | default: ''
  if artwork_status == blank
    assign artwork_status = artwork_mf.value | default: ''
  endif
  if artwork_status == blank
    assign artwork_status = artwork_mf | default: ''
  endif

  assign overall_updated     = shop.metafields.workshop_status.overall_updated.value         | default: shop.metafields.workshop_status.overall_updated         | default: ''
  assign dtf_updated         = shop.metafields.workshop_status.dtf_updated.value             | default: shop.metafields.workshop_status.dtf_updated             | default: ''
  assign uv_dtf_updated      = shop.metafields.workshop_status.uv_dtf_updated.value          | default: shop.metafields.workshop_status.uv_dtf_updated          | default: ''
  assign vinyl_updated       = shop.metafields.workshop_status.vinyl_stickers_updated.value  | default: shop.metafields.workshop_status.vinyl_stickers_updated  | default: ''
  assign sublimation_updated = shop.metafields.workshop_status.sublimation_updated.value     | default: shop.metafields.workshop_status.sublimation_updated     | default: ''
  assign artwork_updated     = shop.metafields.workshop_status.artwork_setup_updated.value   | default: shop.metafields.workshop_status.artwork_setup_updated   | default: ''

  if overall_updated == blank
    assign overall_updated = shop.metafields.custom.workshop_status_overall_updated.value | default: shop.metafields.custom.workshop_status_overall_updated | default: ''
  endif
  if dtf_updated == blank
    assign dtf_updated = shop.metafields.custom.workshop_status_dtf_updated.value | default: shop.metafields.custom.workshop_status_dtf_updated | default: ''
  endif
  if uv_dtf_updated == blank
    assign uv_dtf_updated = shop.metafields.custom.workshop_status_uv_dtf_updated.value | default: shop.metafields.custom.workshop_status_uv_dtf_updated | default: ''
  endif
  if vinyl_updated == blank
    assign vinyl_updated = shop.metafields.custom.workshop_status_vinyl_stickers_updated.value | default: shop.metafields.custom.workshop_status_vinyl_stickers_updated | default: ''
  endif
  if sublimation_updated == blank
    assign sublimation_updated = shop.metafields.custom.workshop_status_sublimation_updated.value | default: shop.metafields.custom.workshop_status_sublimation_updated | default: ''
  endif
  if artwork_updated == blank
    assign artwork_updated = shop.metafields.custom.workshop_status_artwork_setup_updated.value | default: shop.metafields.custom.workshop_status_artwork_setup_updated | default: ''
  endif

  if overall_updated == blank
    assign overall_updated = overall_mf.value.updated_at | default: ''
  endif
  if dtf_updated == blank
    assign dtf_updated = dtf_mf.value.updated_at | default: ''
  endif
  if uv_dtf_updated == blank
    assign uv_dtf_updated = uv_dtf_mf.value.updated_at | default: ''
  endif
  if vinyl_updated == blank
    assign vinyl_updated = vinyl_mf.value.updated_at | default: ''
  endif
  if sublimation_updated == blank
    assign sublimation_updated = sublimation_mf.value.updated_at | default: ''
  endif
  if artwork_updated == blank
    assign artwork_updated = artwork_mf.value.updated_at | default: ''
  endif

  assign overall_status     = overall_status     | default: 'Not Busy'
  assign dtf_status         = dtf_status         | default: 'Not Busy'
  assign uv_dtf_status      = uv_dtf_status      | default: 'Not Busy'
  assign vinyl_status       = vinyl_status       | default: 'Not Busy'
  assign sublimation_status = sublimation_status | default: 'Not Busy'
  assign artwork_status     = artwork_status     | default: 'Not Busy'
%}

<style>
  @keyframes wsp3-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  @keyframes wsp3-fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #WS3-{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  #WS3-{{ section.id }} * { box-sizing: border-box; }

  #WS3-{{ section.id }} .ws-wrap {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #WS3-{{ section.id }} .ws-head {
    text-align: center;
    margin-bottom: 36px;
    animation: wsp3-fadeUp 0.4s ease both;
  }

  #WS3-{{ section.id }} .ws-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 999px;
    background: {{ section.settings.card_background_color }};
    border: 0.5px solid rgba(0,0,0,0.08);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.muted_text_color }};
    margin-bottom: 14px;
  }

  #WS3-{{ section.id }} .ws-eyebrow-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #22c55e;
    animation: wsp3-pulse 2s ease-in-out infinite;
  }

  #WS3-{{ section.id }} .ws-h1 {
    margin: 0 0 10px;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: {{ section.settings.text_color }};
  }

  #WS3-{{ section.id }} .ws-sub {
    margin: 0 auto;
    max-width: 520px;
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.65;
    color: {{ section.settings.muted_text_color }};
  }

  #WS3-{{ section.id }} .ws-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 24px 28px;
    border-radius: 14px;
    background: {{ section.settings.card_background_color }};
    border: 0.5px solid rgba(0,0,0,0.08);
    margin-bottom: 12px;
    animation: wsp3-fadeUp 0.4s ease 0.08s both;
  }

  #WS3-{{ section.id }} .ws-hero-info { flex: 1; min-width: 0; }

  #WS3-{{ section.id }} .ws-label {
    margin: 0 0 3px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: {{ section.settings.muted_text_color }};
    opacity: 0.7;
  }

  #WS3-{{ section.id }} .ws-hero-title {
    margin: 0 0 5px;
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: {{ section.settings.text_color }};
  }

  #WS3-{{ section.id }} .ws-hero-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: {{ section.settings.muted_text_color }};
  }

  #WS3-{{ section.id }} .ws-time {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 10px;
    font-size: 0.8rem;
    color: {{ section.settings.muted_text_color }};
    opacity: 0.7;
  }

  #WS3-{{ section.id }} .ws-time svg {
    width: 14px;
    height: 14px;
  }

  #WS3-{{ section.id }} .ws-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #WS3-{{ section.id }} .ws-pill-lg {
    padding: 10px 20px;
    font-size: 0.95rem;
  }

  #WS3-{{ section.id }} .ws-pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    animation: wsp3-pulse 2s ease-in-out infinite;
  }

  #WS3-{{ section.id }} .ws-s-green  { color: #15803d; background: #dcfce7; }
  #WS3-{{ section.id }} .ws-s-amber  { color: #a16207; background: #fef9c3; }
  #WS3-{{ section.id }} .ws-s-orange { color: #c2410c; background: #ffedd5; }
  #WS3-{{ section.id }} .ws-s-red    { color: #b91c1c; background: #fee2e2; }

  #WS3-{{ section.id }} .ws-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  #WS3-{{ section.id }} .ws-card {
    display: flex;
    flex-direction: column;
    padding: 20px 22px;
    border-radius: 14px;
    background: {{ section.settings.card_background_color }};
    border: 0.5px solid rgba(0,0,0,0.08);
    transition: border-color 0.2s ease;
    animation: wsp3-fadeUp 0.4s ease both;
  }

  #WS3-{{ section.id }} .ws-card:hover { border-color: rgba(0,0,0,0.18); }

  #WS3-{{ section.id }} .ws-card:nth-child(1) { animation-delay: 0.13s; }
  #WS3-{{ section.id }} .ws-card:nth-child(2) { animation-delay: 0.16s; }
  #WS3-{{ section.id }} .ws-card:nth-child(3) { animation-delay: 0.19s; }
  #WS3-{{ section.id }} .ws-card:nth-child(4) { animation-delay: 0.22s; }
  #WS3-{{ section.id }} .ws-card:nth-child(5) { animation-delay: 0.25s; }

  #WS3-{{ section.id }} .ws-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  #WS3-{{ section.id }} .ws-card-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #WS3-{{ section.id }} .ws-card-icon svg {
    width: 18px;
    height: 18px;
    stroke-width: 1.5;
  }

  #WS3-{{ section.id }} .ws-icon-green  { background: #dcfce7; color: #15803d; }
  #WS3-{{ section.id }} .ws-icon-amber  { background: #fef9c3; color: #a16207; }
  #WS3-{{ section.id }} .ws-icon-orange { background: #ffedd5; color: #c2410c; }
  #WS3-{{ section.id }} .ws-icon-red    { background: #fee2e2; color: #b91c1c; }

  #WS3-{{ section.id }} .ws-card-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    flex: 1;
    min-width: 0;
  }

  #WS3-{{ section.id }} .ws-card-desc {
    margin: 0 0 auto;
    font-size: 0.88rem;
    line-height: 1.5;
    color: {{ section.settings.muted_text_color }};
    padding-bottom: 14px;
  }

  #WS3-{{ section.id }} .ws-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding-top: 12px;
    border-top: 0.5px solid rgba(0,0,0,0.06);
  }

  #WS3-{{ section.id }} .ws-foot-time {
    font-size: 0.78rem;
    color: {{ section.settings.muted_text_color }};
    opacity: 0.7;
  }

  #WS3-{{ section.id }} .ws-footer {
    text-align: center;
    margin-top: 12px;
    padding: 14px 20px;
    border-radius: 10px;
    background: {{ section.settings.card_background_color }};
    border: 0.5px solid rgba(0,0,0,0.06);
    animation: wsp3-fadeUp 0.4s ease 0.28s both;
  }

  #WS3-{{ section.id }} .ws-footer p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: {{ section.settings.muted_text_color }};
  }

  @media screen and (max-width: 989px) {
    #WS3-{{ section.id }} .ws-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media screen and (max-width: 749px) {
    #WS3-{{ section.id }} .ws-hero {
      flex-direction: column;
      align-items: flex-start;
      padding: 20px;
    }
    #WS3-{{ section.id }} .ws-grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    #WS3-{{ section.id }} .ws-card { padding: 16px 18px; }
  }
</style>

